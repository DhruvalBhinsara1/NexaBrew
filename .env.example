# NexaBrew environment variables — copy to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real keys.

# Supabase — project URL + keys (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser. Used in lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email (receipts). Server-only.
RESEND_API_KEY=
# Optional. Resend's test sandbox only delivers to the account owner until you
# verify a domain. Set this to route ALL receipts to one inbox (demo mode).
RECEIPT_EMAIL_OVERRIDE_TO=
# Optional. Sender address; defaults to "NexaBrew <onboarding@resend.dev>".
# After verifying a domain in Resend, set e.g. "NexaBrew <receipts@yourdomain.com>".
RECEIPT_EMAIL_FROM=

# App URL — used for absolute links in emails, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Razorpay — payment gateway (Dashboard → Settings → API Keys)
# Key ID is safe to expose to the browser (NEXT_PUBLIC_).
# Key Secret is server-only — never expose it.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
